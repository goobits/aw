#compdef aw

_aw() {
  local -a commands
  commands=(
    'commit:manage the shared commit-owner queue'
    'doctor:check the local AW command and repository config'
    'help:show help'
    'install:install AW and repository adapters'
    'owner:run serialized git or package commands'
    'paths:show installed AW paths'
    'repo:run repository maintenance'
  )

  if (( CURRENT == 2 )); then
    _describe 'command' commands
    return
  fi

  case "$words[2]" in
    commit)
      if (( CURRENT == 3 )); then
        compadd block check doctor done help list next poke raw-request request setup status wait
      else
        compadd -- --check --owner --poke --poll --queue-root --root --summary --tab --timeout --verify --wait
      fi
      ;;
    install)
      compadd -- --dry-run --repo
      ;;
    owner)
      compadd git pkg
      ;;
    repo)
      compadd clean doctor measure-git migrate probe-git-config routes worktree
      ;;
  esac
}

_aw "$@"
